        <mxCell id="sCOb5BSYRyESLz4MrXYg-75" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;OCR第三方计费&lt;/h1&gt;&lt;p&gt;1.&amp;nbsp;目前灵基/build&amp;nbsp;实现&amp;nbsp;websearch&amp;nbsp;的方式有两种: 1.&amp;nbsp;本地实现 ,&amp;nbsp;即LLM&amp;nbsp;返回链接后自己打开; 2.&amp;nbsp;LLM&amp;nbsp;内置.&amp;nbsp;第1种不额外计费,&amp;nbsp;第2种需要,&amp;nbsp;并且它是和LLM的调用一起返回的&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1000" y="630" width="640" height="120" as="geometry" />
        </mxCell>
      </root>
